#ifndef VirtualJoyConDriver_h
#define VirtualJoyConDriver_h

#include <Availability.h>
#include <HIDDriverKit/IOUserHIDDevice.iig>
#include <DriverKit/IOService.iig>
#include <DriverKit/IOUserClient.iig>

// Struct for the basic JoyCon Report we will pass from user-space to kernel-space
struct JoyConReportData {
    uint32_t buttons;
    uint8_t dpad;
    int16_t stickLX;
    int16_t stickLY;
    int16_t stickRX;
    int16_t stickRY;
    uint8_t triggerL;
    uint8_t triggerR;
};

struct JoyConMouseReportData {
    uint8_t buttons; // Left=1, Right=2, Middle=4
    int16_t deltaX;
    int16_t deltaY;
    int8_t scroll;
};

struct JoyConNFCReportData {
    uint8_t status;
    uint8_t tagId[7];
    uint8_t payload[32]; // Max read size per chunk
};

struct JoyConRumbleReportData {
    uint8_t lowFrequency;
    uint8_t highFrequency;
    uint8_t active;
    uint8_t reserved;
    uint32_t sequence;
};

struct JoyConHIDModeData {
    uint8_t sdlOnly;
    uint8_t reserved[3];
};

// ---------------------------------------------------------------------------
// Root IOService
// ---------------------------------------------------------------------------
//
// Matches against IOUserResources (the DriverKit equivalent of IOResources in
// the kernel) so it can load on any Mac without needing real hardware as a
// provider. Does NOT publish an HID device by itself — its only job is to
// hand out a VirtualJoyConUserClient, which in turn instantiates the HID
// device dynamically via IOService::Create(). This is the Karabiner pattern
// documented in their DriverKit-VirtualHIDDevice repo, the verified working
// reference for virtual HID dexts on modern macOS. Content was rephrased
// for compliance with licensing restrictions.
class VirtualJoyConDriver : public IOService
{
public:
    virtual bool init() override;
    virtual void free() override;

    virtual kern_return_t Start(IOService * provider) override;
    virtual kern_return_t Stop(IOService * provider) override;
    virtual kern_return_t NewUserClient(uint32_t type, IOUserClient ** userClient) override;
};

// ---------------------------------------------------------------------------
// Virtual Gamepad HID Device (created dynamically from the UserClient)
// ---------------------------------------------------------------------------
//
// Subclasses IOUserHIDDevice and is instantiated when the daemon opens a
// user client. Keep gamepad and mouse as separate IOHIDDevice nubs; Apple's
// GameController stack classified the old composite gamepad+mouse descriptor
// as GCMouse, which kept it out of GCController/System Settings.
class VirtualJoyConGamepadDevice : public IOUserHIDDevice
{
public:
    virtual bool init() override;
    virtual void free() override;

    virtual kern_return_t Start(IOService * provider) override;
    virtual kern_return_t Stop(IOService * provider) override;

    virtual OSDictionary * newDeviceDescription() override;
    virtual OSData * newReportDescriptor() override;

    virtual kern_return_t setReport(IOMemoryDescriptor * report, IOHIDReportType reportType, IOOptionBits options, uint32_t completionTimeout, OSAction * action) override;
    virtual kern_return_t getReport(IOMemoryDescriptor * report, IOHIDReportType reportType, IOOptionBits options, uint32_t completionTimeout, OSAction * action) override;

    // Called from the UserClient when new report data arrives from the daemon.
    kern_return_t dispatchGamepadReport(JoyConReportData reportData) LOCALONLY;
    kern_return_t dispatchNFCReport(JoyConNFCReportData reportData) LOCALONLY;
};

// ---------------------------------------------------------------------------
// Virtual DualSense HID Device (created dynamically from the UserClient)
// ---------------------------------------------------------------------------
//
// Exposes a second, Sony-shaped gamepad while leaving the generic JoyCon2Mac
// gamepad untouched for Chrome's raw Gamepad API path.
class VirtualJoyConDualSenseDevice : public IOUserHIDDevice
{
public:
    virtual bool init() override;
    virtual void free() override;

    virtual kern_return_t Start(IOService * provider) override;
    virtual kern_return_t Stop(IOService * provider) override;

    virtual OSDictionary * newDeviceDescription() override;
    virtual OSData * newReportDescriptor() override;

    virtual kern_return_t setReport(IOMemoryDescriptor * report, IOHIDReportType reportType, IOOptionBits options, uint32_t completionTimeout, OSAction * action) override;
    virtual kern_return_t getReport(IOMemoryDescriptor * report, IOHIDReportType reportType, IOOptionBits options, uint32_t completionTimeout, OSAction * action) override;

    kern_return_t dispatchDualSenseReport(JoyConReportData reportData) LOCALONLY;
};

// ---------------------------------------------------------------------------
// Virtual Mouse HID Device (created dynamically from the UserClient)
// ---------------------------------------------------------------------------
class VirtualJoyConMouseDevice : public IOUserHIDDevice
{
public:
    virtual bool init() override;
    virtual void free() override;

    virtual kern_return_t Start(IOService * provider) override;
    virtual kern_return_t Stop(IOService * provider) override;

    virtual OSDictionary * newDeviceDescription() override;
    virtual OSData * newReportDescriptor() override;

    virtual kern_return_t setReport(IOMemoryDescriptor * report, IOHIDReportType reportType, IOOptionBits options, uint32_t completionTimeout, OSAction * action) override;
    virtual kern_return_t getReport(IOMemoryDescriptor * report, IOHIDReportType reportType, IOOptionBits options, uint32_t completionTimeout, OSAction * action) override;

    kern_return_t dispatchMouseReport(JoyConMouseReportData reportData) LOCALONLY;
};

// ---------------------------------------------------------------------------
// User client
// ---------------------------------------------------------------------------
class VirtualJoyConUserClient : public IOUserClient
{
public:
    virtual bool init() override;
    virtual void free() override;

    void setInitialSDLOnlyMode(bool enabled) LOCALONLY;

    virtual kern_return_t Start(IOService * provider) override;
    virtual kern_return_t Stop(IOService * provider) override;

    virtual kern_return_t ExternalMethod(
        uint64_t selector,
        IOUserClientMethodArguments * arguments,
        const IOUserClientMethodDispatch * dispatch,
        OSObject * target,
        void * reference) override;
};

#endif /* VirtualJoyConDriver_h */
